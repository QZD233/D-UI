{
  "name": "@d-ui/core",
  "version": "0.0.2",
  "type": "module",
  "description": "Vue 3 组件库，基于 Element Plus 扩展而来的动态表单组件",
  "main": "./dist/d-ui.umd.cjs",
  "module": "./dist/d-ui.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://github.com/QZD233/D-UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/QZD233/D-UI",
    "directory": "packages/d-ui"
  },
  "keywords": [
    "vue",
    "element-plus",
    "dynamic-form",
    "vite",
    "vite-plugin",
    "d-ui",
    "d-form"
  ],
  "bugs": {
    "url": "https://github.com/QZD233/D-UI/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/components/DForm/index.d.ts",
        "default": "./dist/d-ui.js"
      },
      "require": {
        "types": "./dist/components/DForm/index.d.cts",
        "default": "./dist/d-ui.umd.cjs"
      }
    },
    "./style.css": "./dist/d-ui.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "lint": "echo 'Add ESLint when needed'",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "element-plus": "^2.6.0",
    "@element-plus/icons-vue": "^2.3.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "element-plus": "^2.6.0",
    "rimraf": "^5.0.0",
    "sass": "^1.81.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "7.2.4",
    "vite-plugin-dts": "^3.9.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}